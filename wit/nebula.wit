package nebula:core;

interface types {
    /// Currency enumeration used for price/quote values
    enum currency {
        EUR,
        USD,
        GBP,
        JPY,
        CAD,
        AUD,
    }

    /// Countries Nebula operates in
    enum country {
        BE,
        US,
        UK,
        JP,
        CA,
        AU,
    }

    /// A single item in an order
    record item {
        sku: string,
        quantity: u32,
        unit-price: f64,
    }

    /// An order with items and destination
    record order {
        order-id: string,
        items: list<item>,
        destination: country,
    }

    /// A stock entry for an item
    record stock {
        sku: string,
        quantity: u32,
        warehouse-id: string,
    }

    /// A price quote for an order
    record quote {
        order-id: string,
        subtotal: f64,
        tax: f64,
        total: f64,
        currency: currency,
    }
}