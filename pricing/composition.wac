// WAC composition for pricing system
package nebula:inventory;

// Instantiate the base components
let currency = new nebula:currency-engine { ... };
let tax = new nebula:tax-engine { ... };

// Instantiate the pricing-api component
let api = new nebula:pricing-api {
    "nebula:pricing/currency-engine": currency["nebula:pricing/currency-engine"],
    "nebula:pricing/tax-engine": tax["nebula:pricing/tax-engine"],
    ...
};

// Export the inventory-api interface
export api.pricing-api;